subnet: 192.168.1.0/24

credentials:
  username: root
  password: changeme  # plaintext — do not commit cameras.yaml to public repos

smb:
  ip: 192.168.1.10
  share: /mnt/cctv
  username: smbuser
  password: smbpass

motion_detection:
  enabled: true
  sensitivity: 90

recording_retention_days: 33  # remove network share recordings older than this many days (default: 33)

timeout: 5  # per-camera connection timeout in seconds (default: 5)
